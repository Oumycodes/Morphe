{
  "expo": {
    "name": "Morphe",
    "slug": "morphe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Morphe uses your camera to scan and track your body progress.",
        "NSPhotoLibraryUsageDescription": "Morphe saves your scan results to your photo library."
      }
    },
    "android": {
      "permissions": ["CAMERA"]
    }
  }
}